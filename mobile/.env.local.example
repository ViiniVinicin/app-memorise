# =============================================================
# MemoRise Mobile — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================

# URL of the backend API server.
# Use your machine's local IP (not localhost) when running on a physical device or emulator.
# Example for local network: http://192.168.1.42:3000
# Example for Android emulator: http://10.0.2.2:3000
# Example for iOS simulator:    http://localhost:3000
EXPO_PUBLIC_API_URL=http://192.168.1.X:3000

# Google OAuth client IDs used by the mobile app.
# Create them in Google Cloud Console and fill the platform-specific values below.
# Web client ID is also used as a safe fallback during local testing.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
