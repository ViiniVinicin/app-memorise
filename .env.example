# =============================================================
# MemoRise Backend - Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/memorise

# Secret key used to sign JWT tokens - use a long random string
JWT_SECRET=change_me_to_a_long_random_secret

# SMTP email settings (used for password reset emails)
# For Gmail: enable 2FA and generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Your machine's local IP on the network (used in password reset deep links)
# Run "ipconfig" on Windows or "ifconfig" on Mac/Linux to find it
# Example: 192.168.1.42
# You can also use an ngrok URL if testing on a physical device
EXPO_IP=192.168.1.X

# Google OAuth client IDs accepted by the backend when validating Google Sign-In.
# These should match the values configured in mobile/.env.local.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Server port (optional - defaults to 3000)
PORT=3000
